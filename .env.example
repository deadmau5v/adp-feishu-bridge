# ════════════════════════════════════════════════════════════
# ADP-NapCatQQ Bridge 配置文件（示例）
# 复制本文件为 .env 后再修改：
#   cp .env.example .env
# 敏感信息（AppKey、Token）只填在 .env 中，不要提交到 git。
# ════════════════════════════════════════════════════════════

# ──────────────── ADP 智能体配置（v2 接口） ────────────────
# v2 文档：https://cloud.tencent.com/document/product/1759/129202
# 默认值一般不用改。

# 对话接口地址
ADP_CHAT_URL=https://wss.lke.cloud.tencent.com/adp/v2/chat

# 必填。应用 AppKey：ADP 控制台 → 应用 → 发布管理 → 调用信息 → API 管理 中获取
ADP_BOT_APP_KEY=

# 默认访客 ID。运行时若 handler 传入了 visitor_id 则会被覆盖（推荐做法：群 group_<id> / 私聊 qq_<id>）
ADP_VISITOR_ID=napcat-bridge

# 流式回包粒度：每积攒多少字符向调用方回包一次（1-100）
ADP_STREAMING_THROTTLE=5

# SSE 请求超时（秒）
ADP_TIMEOUT=120

# ──────────────── NapCatQQ 配置 ────────────────
# 注意：3000 端口经常被占用，本项目默认 3001（与 .env 中 NAPCAT_HTTP_URL 对应）

# 连接模式：reverse_ws（推荐）/ webhook
NAPCAT_CONNECT_MODE=reverse_ws

# ── 反向 WebSocket（NapCat → Bridge）──
NAPCAT_WS_HOST=0.0.0.0
NAPCAT_WS_PORT=8080
NAPCAT_WS_PATH=/onebot/v11/ws
NAPCAT_WS_TOKEN=

# ── Webhook（NapCat → Bridge，备用）──
NAPCAT_WEBHOOK_PATH=/onebot/v11/http
NAPCAT_WEBHOOK_TOKEN=

# ── HTTP API（Bridge → NapCat 发消息）──
NAPCAT_HTTP_URL=http://127.0.0.1:3001
NAPCAT_HTTP_TOKEN=

# ──────────────── Bridge 行为配置 ────────────────

# 触发模式：
#   at     - 群聊中仅 @机器人 时触发；私聊始终触发（默认）
#   always - 所有消息都触发（注意刷屏）
BRIDGE_TRIGGER_MODE=at

# 白名单（逗号分隔）。留空 = 不过滤。
# 群白名单示例：BRIDGE_ALLOWED_GROUPS=123456789,987654321
BRIDGE_ALLOWED_GROUPS=
BRIDGE_ALLOWED_USERS=

# 单条消息最大长度（超出自动分段发送）
BRIDGE_MAX_MSG_LENGTH=4000

# 多轮上下文：每次请求拼入最近 N 轮（user + assistant 各算一轮）。0=不传历史
BRIDGE_MAX_HISTORY_TURNS=6

# 拼好的 user_query 字符上限。超长时按 FIFO 丢历史，System/Context/Current 永远保留
BRIDGE_MAX_QUERY_LENGTH=3000

# 流式发送：true=收到 ADP 片段就分段发；false=攒完整条再发
BRIDGE_STREAMING_SEND=false
BRIDGE_STREAMING_BATCH_SIZE=50

# 日志级别: DEBUG / INFO / WARNING / ERROR
BRIDGE_LOG_LEVEL=INFO

# 打印原始事件（调试用，建议仅开发时打开）
BRIDGE_DEBUG_RAW_EVENT=false

# ──────────────── 系统提示词（可选） ────────────────
# 拼到每次 user_query 头部 [System] 段。多行用 \n 还原。
# 留空则不附加。
# 默认样例：QQ 场景下禁用 Markdown。
BRIDGE_SYSTEM_PROMPTS=你正在通过 QQ 聊天机器人回复用户。\n严禁使用 Markdown 格式：不要用 # 标题、**粗体**、*斜体*、代码块、列表符号、链接语法等任何 Markdown 标记。\n如需强调请直接用纯文本大写或加双引号。\n回复语言与用户消息保持一致。\n调用工具时请静默执行，不要输出"我先去查一下""我换个方式"等进度描述，等工具结果回来后直接给最终答案。\n如果用户输入中包含 [Context]/[History]/[Current] 等结构化元数据，请把元数据当作"对话上下文"理解，按里面的真实人类消息回复，不要复述元数据标签。