# ════════════════════════════════════════════════════════════
# ADP-Feishu Bridge 配置文件（示例）
# 复制本文件为 .env 后再修改：
#   cp .env.example .env
# 敏感信息（AppKey / AppSecret）只填在 .env 中，不要提交到 git。
# ════════════════════════════════════════════════════════════

# ──────────────── ADP 智能体配置（v2 接口） ────────────────
# v2 文档：https://cloud.tencent.com/document/product/1759/129202
# 默认值一般不用改。

# 对话接口地址
ADP_CHAT_URL=https://wss.lke.cloud.tencent.com/adp/v2/chat

# 必填。应用 AppKey：ADP 控制台 → 应用 → 发布管理 → 调用信息 → API 管理 中获取
ADP_BOT_APP_KEY=

# 默认访客 ID。运行时若 handler 传入了 visitor_id 则会被覆盖（推荐做法：群 group_<id> / 私聊 feishu_<open_id>）
ADP_VISITOR_ID=feishu-bridge

# 流式回包粒度：每积攒多少字符向调用方回包一次（1-100）
ADP_STREAMING_THROTTLE=5

# SSE 请求超时（秒）
ADP_TIMEOUT=120

# ──────────────── 飞书应用配置 ────────────────
# 飞书自建应用：开发者后台 → 我的应用 → 创建企业自建应用
# 1) 能力 / 机器人能力：开启
# 2) 事件订阅：订阅方式选「使用长连接接收事件」，添加 im.message.receive_v1
# 3) 权限：im:message, im:message.group_at_msg, im:message.p2p_msg, im:message:send_as_bot
# 4) 版本管理：创建版本并申请发布（企业自建应用需管理员审批）

# 必填。飞书应用的 App ID（cli_ 开头）
FEISHU_APP_ID=

# 必填。飞书应用的 App Secret
FEISHU_APP_SECRET=

# 飞书域名：feishu（飞书，国内）/ lark（Lark，海外）。默认 feishu
FEISHU_DOMAIN=feishu

# 强烈建议填写：机器人自己的 open_id。
# 用于群聊里准确识别"@机器人"消息（不填则群聊 @机器人 触发逻辑失效）。
# 获取方法：飞书管理后台 → 用户与部门 → 搜索机器人名字 → 复制 open_id
FEISHU_BOT_OPEN_ID=

# 飞书 SDK 日志级别：DEBUG / INFO / WARNING / ERROR
FEISHU_LOG_LEVEL=INFO

# ──────────────── Bridge 行为配置 ────────────────

# 触发模式：
#   at     - 群聊中仅 @机器人 时触发；私聊始终触发（默认）
#   always - 所有消息都触发（注意刷屏）
BRIDGE_TRIGGER_MODE=at

# 白名单（逗号分隔）。留空 = 不过滤。
# chat 白名单示例：BRIDGE_ALLOWED_CHATS=oc_xxx1,oc_xxx2
#   （私聊 chat_id 也是 oc_ 开头，可以在日志中观察）
# user 白名单示例：BRIDGE_ALLOWED_USERS=ou_xxx1,ou_xxx2
BRIDGE_ALLOWED_CHATS=
BRIDGE_ALLOWED_USERS=

# 单条消息最大长度（超出自动分段发送）
BRIDGE_MAX_MSG_LENGTH=4000

# 多轮上下文：每次请求拼入最近 N 轮（user + assistant 各算一轮）。0=不传历史
BRIDGE_MAX_HISTORY_TURNS=6

# 拼好的 user_query 字符上限。超长时按 FIFO 丢历史，System/Context/Current 永远保留
BRIDGE_MAX_QUERY_LENGTH=3000

# 流式发送：true=收到 ADP 片段就分段发；false=攒完整条再发
BRIDGE_STREAMING_SEND=false
BRIDGE_STREAMING_BATCH_SIZE=50

# 日志级别: DEBUG / INFO / WARNING / ERROR
BRIDGE_LOG_LEVEL=INFO

# 打印原始事件（调试用，建议仅开发时打开）
BRIDGE_DEBUG_RAW_EVENT=false

# 服务监听端口（FastAPI 健康检查用）
BRIDGE_PORT=8080

# ──────────────── 系统提示词（可选） ────────────────
# 拼到每次 user_query 头部 [System] 段。多行用 \n 还原。
# 留空则不附加。
# 默认样例：飞书场景下输出纯文本，不带 Markdown。
BRIDGE_SYSTEM_PROMPTS=你正在通过飞书聊天机器人回复用户。\n请使用纯文本回复：不要用 # 标题、**粗体**、*斜体*、代码块、列表符号、链接语法等任何 Markdown 标记。\n如需强调请直接用纯文本大写或加双引号。\n回复语言与用户消息保持一致。\n调用工具时请静默执行，不要输出"我先去查一下""我换个方式"等进度描述，等工具结果回来后直接给最终答案。\n如果用户输入中包含 [Context]/[History]/[Current] 等结构化元数据，请把元数据当作"对话上下文"理解，按里面的真实人类消息回复，不要复述元数据标签。
